# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:55421
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# AI (future use)
DEEPSEEK_API_KEY=your_deepseek_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key

# Reading provider
AETHERTAROT_READING_PROVIDER=llm

# Optional llm baseline (OpenAI-compatible / DashScope-compatible)

AETHERTAROT_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
AETHERTAROT_LLM_MODEL=qwen3.6-flash
AETHERTAROT_LLM_API_KEY=$DASHSCOPE_API_KEY
AETHERTAROT_LLM_TEMPERATURE=0.3
AETHERTAROT_LLM_TIMEOUT_MS=120000
AETHERTAROT_LLM_MAX_OUTPUT_TOKENS=1800
AETHERTAROT_LLM_DAILY_COST_LIMIT_USD=1.00
AETHERTAROT_LLM_COST_RESERVATION_USD=0.05
AETHERTAROT_LLM_INPUT_COST_PER_1K_USD=0.001
AETHERTAROT_LLM_OUTPUT_COST_PER_1K_USD=0.002

# Beta access, quota, and observability
AETHERTAROT_READING_DAILY_LIMIT_PER_EMAIL=5
AETHERTAROT_READING_IP_LIMIT_PER_MINUTE=3
AETHERTAROT_READING_IP_LIMIT_PER_DAY=20
AETHERTAROT_IP_HASH_SALT=replace_with_random_secret

# LangSmith (future use)
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=aether-tarot
